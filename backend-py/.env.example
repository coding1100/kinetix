# 1. Copy docker-compose.env.example → ../docker-compose.env and start Postgres:
#    docker compose up -d postgres
# 2. Copy this file to .env and match POSTGRES_* credentials from docker-compose.env
DATABASE_URL="postgresql://riseup:change-me-strong-password@127.0.0.1:5432/riseup"

PORT=4001
FRONTEND_URL="http://localhost:3001"
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_MINUTES=240
JWT_REFRESH_EXPIRES_DAYS=7
RESET_TOKEN_EXPIRES_HOURS=1
NODE_ENV="development"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
API_PUBLIC_URL="http://localhost:4001"

# Workspace invite emails (required for real invite delivery)
# Gmail: use an App Password — https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Kinetix <your@gmail.com>"
SMTP_USE_TLS=true
SMTP_USE_SSL=false
