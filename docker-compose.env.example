# Copy to docker-compose.env (gitignored) for local dev and on EC2.
POSTGRES_USER=riseup
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=riseup

# Full Docker stack — always pass: docker compose --env-file docker-compose.env ...
PUBLIC_APP_URL=http://localhost
API_PUBLIC_URL=http://localhost
FRONTEND_URL=http://localhost
# POSTGRES_PASSWORD above is used to build DATABASE_URL for the api container (@postgres host).
# You do not need DATABASE_URL here unless you override the default in docker-compose.app.yml.

# POSTGRES_HOST_PORT=5432
# HTTP_PORT=80
