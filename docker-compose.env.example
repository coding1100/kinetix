# Local dev — copy to docker-compose.env (gitignored)
# Production EC2 uses its own docker-compose.env (strong password + PUBLIC_APP_URL).

POSTGRES_USER=riseup
POSTGRES_PASSWORD=riseup
POSTGRES_DB=riseup

# If port 5432 is taken on Windows, set POSTGRES_HOST_PORT=5433 in repo root `.env`
# and use the same port in backend-py/.env DATABASE_URL below.
POSTGRES_HOST_PORT=5432

# --- EC2 production only (docker-compose.app.yml) — add these on the server, not for local hybrid:
# PUBLIC_APP_URL=http://3.140.5.67
# API_PUBLIC_URL=http://3.140.5.67
# FRONTEND_URL=http://3.140.5.67
# POSTGRES_PASSWORD=<strong-production-password>
