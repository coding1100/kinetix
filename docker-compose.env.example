# Copy to docker-compose.env (gitignored) for local dev and on EC2.
POSTGRES_USER=riseup
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=riseup

# Full Docker stack — always pass: docker compose --env-file docker-compose.env ...
PUBLIC_APP_URL=http://localhost
API_PUBLIC_URL=http://localhost
FRONTEND_URL=http://localhost
# API in Docker must use hostname "postgres", not 127.0.0.1
DATABASE_URL=postgresql://riseup:change-me-strong-password@postgres:5432/riseup

# POSTGRES_HOST_PORT=5432
# HTTP_PORT=80
