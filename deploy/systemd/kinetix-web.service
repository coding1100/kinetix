[Unit]
Description=Kinetix Web (Next.js)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/clickup/kinetix/frontend
Environment=NODE_ENV=production
Environment=PORT=3000
ExecStartPre=/bin/sh -c 'pkill -f "next dev" || true'
ExecStart=/opt/clickup/kinetix/frontend/node_modules/.bin/next start -p 3000 -H 127.0.0.1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
